#!/bin/sh

# Get staged PHP files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$')

# Exit early if no PHP files staged
if [ -z "$STAGED_FILES" ]; then
  echo "No PHP files staged for Pint."
else
  echo "Running Laravel Pint on staged files..."

  # Run Pint only on staged files
  ./vendor/bin/pint $STAGED_FILES
  PINT_STATUS=$?

  if [ $PINT_STATUS -ne 0 ]; then
    echo "❌ Pint failed."
    exit 1
  fi

  # Re-stage files after Pint modifies them
  echo "$STAGED_FILES" | xargs git add
fi

echo "Running PHPUnit tests..."
composer run test
TEST_STATUS=$?

if [ $TEST_STATUS -ne 0 ]; then
  echo "❌ Tests failed."
  exit 1
fi

echo "✅ All good."
exit 0
